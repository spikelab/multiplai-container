# multiplai-container build/run configuration.
# Copy to .env and fill in your values:  cp .env.example .env
# (When this repo lives inside a multiplai-kit checkout as container/,
# the kit root's .env is used instead and this file is ignored.)

# Absolute path of the workspace directory to mount into the container.
# A leading ~ or $HOME is expanded by build.sh.
WORKSPACE="$HOME/your-workspace"

# Docker image tag produced by build.sh (default: claude-multiplai:local)
#IMAGE_NAME="claude-multiplai:local"

# UID/GID the in-container `agent` user maps to (default: your current ids).
# Must match the owner of WORKSPACE on the host or mounted files will be
# unwritable.
#HOST_UID=501
#HOST_GID=20

# --- macOS host bridge (optional; see README "Host bridge" section) ---
# Username the container SSHes into on the Mac host (default: $USER at build).
#SSH_BUILD_USER="you"

# Private key mounted into the container at /home/agent/.ssh/build_key.
# Generate with: ssh-keygen -t ed25519 -f ~/.ssh/build_key -N ''
#SSH_BUILD_KEY="$HOME/.ssh/build_key"
